{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        {
          "url": "ms-settings:bluetooth"
        }
      ]
    },
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir",
    "store:default",
    "dialog:default"
  ]
}